generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LinkItem {
  id        Int       @id @default(autoincrement())
  finalCode String    @unique
  mainUrl   String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  clicks    Int       @default(0)
}
